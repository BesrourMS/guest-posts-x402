# Your real Base wallet address that receives payments
PAY_TO=0xYourRealBaseWalletAddress

# Shared secret for the /submissions admin endpoints (send as X-Admin-Token header)
ADMIN_TOKEN=change-me

# "mainnet" to use Base mainnet, anything else (or unset) uses Base Sepolia testnet
X402_NETWORK=testnet

# Optional, defaults to $5.00
GUEST_POST_PRICE=$5.00

# Cloudflare D1 access (Workers dashboard -> your D1 database -> Settings)
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_D1_DATABASE_ID=your_d1_database_id
# API token needs "D1: Edit" permission — create at dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=your_cloudflare_api_token
